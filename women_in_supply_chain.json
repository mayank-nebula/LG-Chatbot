import { cache } from "react";
import { env } from "@/lib/env";

/**
 * Generic function to fetch page content from WordPress REST API with ISR
 * Use this for pages - data will be revalidated every 60 minutes
 * @template T - The type of data being fetched
 * @param endpoint - The API endpoint (e.g., 'about-us-page')
 * @param errorMessage - Custom error message if fetch fails
 * @returns Promise containing the typed page content
 */
export async function fetchPageContent<T>(
  endpoint: string,
  errorMessage: string = `Failed to fetch content from ${endpoint}`,
): Promise<T> {
  const timestamp = Date.now();
  const res = await fetch(
    `${env.SITE_URL}/wp-json/site/v1/options/${endpoint}?t=${timestamp}`,
    {
      next: { revalidate: 3600 }, // ISR: Revalidate every 60 minutes
    },
  );

  if (!res.ok) {
    throw new Error(errorMessage);
  }

  return res.json() as Promise<T>;
}

/**
 * Cached version of fetchPageContent for components (header, footer, etc.)
 * Uses React's cache() to deduplicate requests within a single render
 * @template T - The type of data being fetched
 * @param endpoint - The API endpoint (e.g., 'header')
 * @param errorMessage - Custom error message if fetch fails
 * @returns Promise containing the typed page content
 */
export const fetchPageContentCached = cache(async function <T>(
  endpoint: string,
  errorMessage: string = `Failed to fetch content from ${endpoint}`,
): Promise<T> {
  const timestamp = Date.now();
  const res = await fetch(
    `${env.SITE_URL}/wp-json/site/v1/options/${endpoint}?t=${timestamp}`,
    {
      next: { revalidate: 3600 }, // ISR: Revalidate every 60 minutes
    },
  );

  if (!res.ok) {
    throw new Error(errorMessage);
  }

  return res.json() as Promise<T>;
});
