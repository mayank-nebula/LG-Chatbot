import { unstable_cache } from "next/cache";
import { env } from "@/lib/env";

/**
 * Build WordPress API URL
 * Centralized URL creation
 */
function buildWpUrl(endpoint: string) {
  const timestamp = Date.now();
  return `${env.SITE_URL}/wp-json/site/v1/options/${endpoint}?t=${timestamp}`;
}

/**
 * Base fetcher (no caching logic here)
 */
async function fetchFromWordPress<T>(
  endpoint: string,
  errorMessage: string = `Failed to fetch content from ${endpoint}`,
): Promise<T> {
  const url = buildWpUrl(endpoint);

  const res = await fetch(url, {
    cache: "no-store", // let unstable_cache control caching
  });

  if (!res.ok) {
    throw new Error(errorMessage);
  }

  return res.json() as Promise<T>;
}

/**
 * Page-level fetch with ISR (unchanged behavior)
 */
export async function fetchPageContent<T>(
  endpoint: string,
  errorMessage: string = `Failed to fetch content from ${endpoint}`,
): Promise<T> {
  const res = await fetch(buildWpUrl(endpoint), {
    next: { revalidate: 3600 }, // ISR: 60 minutes
  });

  if (!res.ok) {
    throw new Error(errorMessage);
  }

  return res.json() as Promise<T>;
}

/**
 * Global cached version for shared components (header, footer, etc.)
 * Cache key is based on endpoint slug
 * Shared across users
 */
export async function fetchPageContentCached<T>(
  endpoint: string,
  errorMessage: string = `Failed to fetch content from ${endpoint}`,
): Promise<T> {
  const cachedFn = unstable_cache(
    async () => fetchFromWordPress<T>(endpoint, errorMessage),
    ["wp-options", endpoint], // cache key based on endpoint
    {
      revalidate: 3600, // 60 minutes
    },
  );

  return cachedFn();
}
